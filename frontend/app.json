{
  "expo": {
    "name": "B-SNAP",
    "slug": "b-snap",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EEF2F6"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "B-SNAP이 사진을 가져와 노트 워크스페이스에 연결할 수 있도록 사진 접근 권한이 필요합니다.",
          "cameraPermission": "B-SNAP이 판서를 촬영해 현재 수업 노트에 바로 연결할 수 있도록 카메라 권한이 필요합니다."
        }
      ],
      "expo-document-picker"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.b-snap"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EEF2F6"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.anonymous.bsnap"
    }
  }
}