{
  "name": "b-snap",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "backend": "node scripts/run-backend.js",
    "backend:dev": "node scripts/run-backend.js --reload",
    "start": "expo start --dev-client",
    "start:reset": "expo start --dev-client -c",
    "web": "expo start --web",
    "android": "node scripts/run-android.js",
    "ios": "react-native run-ios --no-packager",
    "ios:ipad": "react-native run-ios --simulator \"iPad (A16)\" --no-packager",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.10",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "perfect-freehand": "^1.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pdf": "^7.0.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.6",
    "typescript": "~5.9.2"
  }
}
